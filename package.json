{
  "name": "schemacraft-ai",
  "version": "0.7.1",
  "private": true,
  "description": "AI-powered developer tool that converts natural language prompts into SQL schemas, Drizzle ORM models, sample JSON, Markdown documentation, and Mermaid ER diagrams.",
  "homepage": "https://schemacraft-ai.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagat546/schemacraft-ai.git"
  },
  "bugs": {
    "url": "https://github.com/jagat546/schemacraft-ai/issues"
  },
  "keywords": [
    "sql",
    "schema-generator",
    "drizzle-orm",
    "gemini",
    "ai",
    "postgresql",
    "supabase",
    "nextjs"
  ],
  "author": "Jagat Jyoti Mishra",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:apply-sql": "node scripts/apply-supabase-sql.mjs",
    "db:setup": "npm run db:migrate && npm run db:apply-sql"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@google/genai": "^2.12.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.25.0",
    "mermaid": "^11.16.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.82.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
